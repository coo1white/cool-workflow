{
  "name": "cool-workflow",
  "version": "0.1.87",
  "bin": {
    "cool-workflow": "scripts/cw.js",
    "cw": "scripts/cw.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coo1white/cool-workflow.git",
    "directory": "plugins/cool-workflow"
  },
  "homepage": "https://github.com/coo1white/cool-workflow#readme",
  "bugs": {
    "url": "https://github.com/coo1white/cool-workflow/issues"
  },
  "description": "A workflow control plane and run-time you are able to check: it sends out jobs in TypeScript, makes certain of work against facts before it goes through, puts state into fixed records, orders jobs by time, runs jobs again and again, gets a group of agents to do their parts together, and talks MCP. It gives the doing of the work to outside agents — it never runs the models itself.",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "license": "BSD-2-Clause",
  "author": {
    "name": "COOLWHITE LLC"
  },
  "files": [
    ".claude-plugin/",
    ".codex-plugin/",
    ".mcp.json",
    "manifest/",
    "README.md",
    "apps/",
    "dist/",
    "docs/",
    "scripts/",
    "skills/",
    "ui/",
    "workflows/",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dist:check": "node scripts/dist-drift-check.js",
    "golden-path": "node scripts/golden-path.js",
    "dogfood:release": "node scripts/dogfood-release.js",
    "canonical-apps": "node scripts/canonical-apps.js",
    "fixture-compat": "node test/run-fixture-compat-smoke.js",
    "sync:project-index": "node scripts/sync-project-index.js",
    "index:check": "node scripts/sync-project-index.js --check",
    "bump:version": "node scripts/bump-version.js",
    "new:feature": "node scripts/new-feature.js",
    "forward-ref": "node scripts/forward-ref-docs.js",
    "verify:container": "node scripts/verify-container-selfref.js",
    "gen:manifests": "node scripts/gen-manifests.js",
    "gen:parity": "node scripts/gen-parity-doc.js",
    "manifest:load-check": "node test/vendor-manifest-load-smoke.js",
    "parity:check": "node scripts/parity-check.js --check",
    "onramp:check": "node scripts/onramp-check.js --check",
    "version:sync": "node scripts/version-sync-check.js",
    "release:check": "node scripts/release-check.js",
    "test": "node dist/cli.js version > /dev/null && node test/run-all.js",
    "test:fast": "npm run build --if-present && node dist/cli.js version > /dev/null && node test/run-all.js --concurrency auto",
    "test:ci": "node dist/cli.js version > /dev/null && node test/run-all.js --concurrency auto",
    "test:coverage": "node dist/cli.js version > /dev/null && node scripts/coverage-gate.js --concurrency auto",
    "eval:replay": "tsc -p tsconfig.json && node test/multi-agent-eval-replay-harness-smoke.js",
    "ci": "npm run build && npm run check && npm run test && npm run release:check",
    "validate:schema": "node scripts/validate-run-state-schema.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "keywords": [
    "agent",
    "workflow",
    "control-plane",
    "mcp",
    "multi-agent",
    "orchestration",
    "audit",
    "llm-pipeline",
    "claude",
    "delegation"
  ]
}
