.DS_Store
Thumbs.db

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun.lockb

.cw/
# Ephemeral release-gate pass markers; the reviewer verdict (review-*.verdict)
# stays tracked so the tag-push CI can confirm an APPROVED review was committed.
.cw-release/gate-*.ok
# Transient GitHub-Release notes bodies (regenerated from CHANGELOG + verdict).
.cw-release/release-notes-*.md
# Reviewer prompt inputs may include local checkout details and are regenerated.
.cw-release/review-input-*.md
# Reviewer agent narration transcript — written per-cut, may carry local paths
# (e.g. the operator's home dir), so it must never ride into the tag commit.
.cw-release/transcript*.md
coverage/
.nyc_output/
.turbo/
.cache/

*.tsbuildinfo

# Keep runtime builds for the distributable Codex plugin.
!plugins/cool-workflow/dist/
!plugins/cool-workflow/dist/**/*.js
